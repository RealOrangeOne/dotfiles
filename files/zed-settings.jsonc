{
  "proxy": "",
  "auto_install_extensions": {
    "html": true,
    "git-firefly": true,
    "toml": true,
    "dockerfile": true,
    "scss": true,
    "make": true,
    "material-icon-theme": true,
    "terraform": true,
    "github-theme": true,
    "nginx": true,
    "ansible": true,
    "just": true,
    "helm": true,
    "jinja2": true,
  },
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "default_profile": "minimal",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "anthropic",
      "model": "claude-sonnet-4-6"
    },
    "model_parameters": []
  },
  "format_on_save": "off",
  "icon_theme": "Material Icon Theme",
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "base_keymap": "SublimeText",
  "buffer_font_family": "Fira Code",
  "buffer_font_weight": 300,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "GitHub Dark Dimmed"
  },
  "load_direnv": "shell_hook",
  "minimap": {
    "show": "auto",
    "thumb": "hover"
  },
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "tabs": {
    "file_icons": true,
    "activate_on_close": "neighbour"
  },
  "git": {
    "enable_status": true,
    "inline_blame": {
      "enabled": false
    }
  },
  "middle_click_paste": false,
  "telemetry": {
    "diagnostics": false
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false
    },
    "font_size": 15
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_sign_in": false
  },
  "project_panel": {
    "dock": "left",
    "indent_size": 15
  },
}
